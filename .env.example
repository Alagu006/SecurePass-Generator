# Database Configuration (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5555
DB_NAME=password_security_db

# App Configuration
# IMPORTANT: Generate a secure SECRET_KEY using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-secure-key-here
FLASK_ENV=development

# Security Settings
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# Email Configuration (for password reset & confirmation)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@passwordsecurity.com

# Redis Configuration (for rate limiting)
# Use memory:// for development, redis://localhost:6379/0 for production
REDIS_URL=memory://

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
